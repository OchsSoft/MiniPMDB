{
  "name": "minipmdb",
  "version": "0.1.0",
  "description": "CI for governed cross-project agent memory.",
  "type": "module",
  "license": "MPL-2.0",
  "bin": {
    "minipmdb": "./src/cli.js"
  },
  "exports": {
    ".": "./src/service.js",
    "./audit": "./src/audit.js",
    "./context": "./src/context.js"
  },
  "scripts": {
    "start": "node src/api.js",
    "mcp": "node src/mcp.js",
    "test": "node --test --test-concurrency=1",
    "check": "node scripts/check.js",
    "sanitize": "node scripts/sanitize-check.js",
    "judge:demo": "node scripts/judge-demo.js",
    "judge:dry-run": "node scripts/judge-dry-run.js",
    "video:serve": "node video/serve.mjs",
    "video:render": "node video/render.mjs",
    "smoke": "node src/cli.js audit-snapshot --strict --snapshot examples/release-guard/resolved.json && node scripts/snapshot-context.js",
    "demo:reset": "node src/cli.js demo reset",
    "demo:fix": "node src/cli.js demo fix",
    "demo:audit": "node src/cli.js audit --strict"
  },
  "engines": {
    "node": ">=20.19"
  },
  "dependencies": {
    "mongodb": "7.5.0",
    "mongodb-memory-server-core": "11.2.0"
  }
}
